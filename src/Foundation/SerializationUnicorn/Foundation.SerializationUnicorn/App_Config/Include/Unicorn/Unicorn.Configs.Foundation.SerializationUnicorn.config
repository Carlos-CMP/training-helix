<!--
    Unicorn.Configs.Foundation.SerializationUnicorn.config

    Configuración de serialización Unicorn para el módulo Foundation.SerializationUnicorn.
    Módulo de prueba para practicar la serialización con Unicorn en paralelo a Sitecore CLI.

    Paths serializados: /sitecore/templates/Foundation/SerializationUnicorn
-->
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/" xmlns:role="http://www.sitecore.net/xmlconfig/role/">
    <sitecore>
        <unicorn>
            <configurations>
                <!--
                    Nombre en formato Helix (Layer.Module) para poder usar $(layer) y $(module) como variables.
                    Este módulo serializa únicamente items bajo Foundation/SerializationUnicorn,
                    sin interferir con los paths gestionados por Sitecore CLI.
                -->
                <configuration name="Foundation.SerializationUnicorn" description="Serialización de prueba con Unicorn para el módulo Foundation.SerializationUnicorn">
                    <predicate>
                        <include name="templates" database="master" path="/sitecore/templates/Foundation/SerializationUnicorn" />
                    </predicate>

                    <dataProviderConfiguration enableTransparentSync="false" />

                    <syncConfiguration updateLinkDatabase="false" updateSearchIndex="false" />
                </configuration>
            </configurations>
        </unicorn>
    </sitecore>
</configuration>
